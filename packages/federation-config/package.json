{
  "name": "@mfe/federation-config",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./runtime": { "types": "./dist/runtime.d.ts", "import": "./dist/runtime.js" }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/runtime.ts --format esm --clean && rm -f .tsbuildinfo && tsc --project tsconfig.json",
    "dev": "tsup src/index.ts src/runtime.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@module-federation/vite": "^1.14.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.6.3"
  }
}
